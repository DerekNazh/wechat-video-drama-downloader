# 项目版本
PROJECT_VERSION=1.3.1

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=DEBUG

# 前端轮询后端服务状态的间隔（秒）
WX_STATUS_INTERVAL=3

# 分别  微信视频号下载器和短剧下载器的路径和视频下载目录（相对 app_root，也可用绝对路径）
WX_DOWNLOAD_DIR=下载/作者资源
SHORT_DRAMA_DOWNLOAD_DIR=下载/短剧


# 最大并发下载数（1-20）
MAX_CONCURRENT=5
DOC_SYNC_INTERVAL=5

# 广告总开关（true=显示 / false=隐藏）
ADS_ENABLED=false

# pywebview 调试模式（true=开启开发者工具 / false=关闭）
PYWEBVIEW_DEBUG=true


# ========== 自动同步的配置项 ==========
# 短剧嗅探服务端口（res_download.exe）
RES_PORT=8899
# 短剧嗅探上游代理端口（weixin_download 内部代理）
RES_UPSTREAM_PORT=2023
# 启动时自动开启系统代理（短剧嗅探需要）
RES_AUTO_PROXY=true