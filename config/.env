# 项目版本
PROJECT_VERSION=1.2.0

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=DEBUG

# 前端轮询后端服务状态的间隔（秒）
WX_STATUS_INTERVAL=3

# 视频下载目录（相对 app_root，也可用绝对路径）
WX_DOWNLOAD_DIR=下载

# 最大并发下载数（1-20）
MAX_CONCURRENT=5
DOC_SYNC_INTERVAL=5

# 广告总开关（true=显示 / false=隐藏）
ADS_ENABLED=false

# pywebview 调试模式（true=开启开发者工具 / false=关闭）
PYWEBVIEW_DEBUG=true
