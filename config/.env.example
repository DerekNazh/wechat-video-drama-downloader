# 项目版本
PROJECT_VERSION=1.0.0

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 前端轮询后端服务状态的间隔（秒）
WX_STATUS_INTERVAL=5

# 视频下载目录（相对 app_root，也可用绝对路径）
WX_DOWNLOAD_DIR=下载

# 短剧嗅探服务端口（res_download.exe）
RES_PORT=8899

# 短剧嗅探上游代理端口（weixin_download 内部代理）
RES_UPSTREAM_PORT=2023

# 启动时自动开启系统代理（短剧嗅探需要）
RES_AUTO_PROXY=true

# 广告总开关（true=显示 / false=隐藏）
ADS_ENABLED=true

# pywebview 调试模式（true=开启开发者工具 / false=关闭）
PYWEBVIEW_DEBUG=false
